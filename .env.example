# ============================================
# 網站基礎設定
# ============================================
# 網站基礎 URL（用於產生訂單詳情連結、取消訂閱連結等）
NEXT_PUBLIC_SITE_URL=https://fest.dna.org.tw

# ============================================
# Stripe 付款設定
# ============================================
# Stripe Secret Key（後端使用）
STRIPE_SECRET_KEY=sk_xxxxxxxxxxxxx

# Stripe Price IDs（票種價格 ID）
STRIPE_PRICE_EXPLORE=price_xxxxxxxxxxxxx
STRIPE_PRICE_CONTRIBUTE=price_xxxxxxxxxxxxx
STRIPE_PRICE_BACKER=price_xxxxxxxxxxxxx

# ============================================
# reCAPTCHA Enterprise 配置
# ============================================
# reCAPTCHA Enterprise Site Key（前端使用）
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lcu81gsAAAAAIrVoGK7urIEt9_w7gOoUSjzC5Uv

# reCAPTCHA Enterprise API Key（後端驗證使用）
RECAPTCHA_API_KEY=your_recaptcha_api_key

# reCAPTCHA Project ID（後端驗證使用）
RECAPTCHA_PROJECT_ID=tdna-1769599168858

# reCAPTCHA 最低通過分數（0.0 ~ 1.0，預設 0.7；敏感操作建議不低於 0.7）
RECAPTCHA_MIN_SCORE=0.7

# ============================================
# Mailgun 電子郵件服務設定
# ============================================
# Mailgun API Key
MAILGUN_API_KEY=your_mailgun_api_key

# Mailgun 網域（必須是在 Mailgun 中驗證過的網域）
MAILGUN_DOMAIN=yourdomain.com

# 寄件人電子郵件位址（必須使用驗證過的網域）
EMAIL_FROM=noreply@yourdomain.com

# 取消訂閱 Token 金鑰（用於產生與驗證取消訂閱連結，建議使用隨機字串）
UNSUBSCRIBE_SECRET=your_random_secret_key_here

# ============================================
# Supabase 配置（如果使用）
# ============================================
# Supabase URL（前端使用）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Publishable Key（前端使用，取代舊版 Anon Key）
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key

# Supabase Secret Key（後端使用，取代舊版 Service Role Key）
SUPABASE_SECRET_KEY=sb_secret_your_secret_key

# 自訂 Magic Link 認證密鑰（用於簽發 JWT session token，建議使用隨機字串）
AUTH_SECRET=your-auth-secret-key-here-change-in-production

# 投票確認 token 金鑰（用於產生與驗證投票確認連結）
VOTE_SECRET=your-secret-key-here-change-in-production

STRIPE_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# Meta Conversions API（可選）
# ============================================
# 前端 Pixel ID（若不填，會使用 components/FacebookPixel.tsx 內建預設值）
NEXT_PUBLIC_META_PIXEL_ID=1740357633585300

# 後端 CAPI Pixel ID（通常與 NEXT_PUBLIC_META_PIXEL_ID 相同）
META_CAPI_PIXEL_ID=1740357633585300

# Meta Conversions API Access Token（Events Manager 產生）
META_CAPI_ACCESS_TOKEN=

# 測試事件碼（開發測試時可填，正式環境留空）
META_CAPI_TEST_EVENT_CODE=

# Graph API 版本（可選，預設 v23.0）
META_CAPI_API_VERSION=v23.0